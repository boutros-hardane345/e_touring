{
  "name": "e-touring-fullstack",
  "version": "1.0.0",
  "description": "Eco-tourism full-stack application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "client": "browser-sync start --server 'frontend' --files 'frontend' --port 3000 --no-open",
    "dev-full": "concurrently \"npm run dev\" \"npm run client\"",
    "postinstall": "if not exist frontend mkdir frontend && type nul > frontend/index.html",
    "audit-fix": "npm audit fix",
    "clean": "rmdir /s /q node_modules && del package-lock.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "multer": "^2.0.0",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "browser-sync": "^2.29.3",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}